APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# SQLite (default)
DATABASE_URL=sqlite+aiosqlite:///./papersearch.db
# Postgres 示例
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/papersearch

REDIS_URL=redis://localhost:6379/0

SECRET_KEY=please-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

OPENAI_API_KEY=
DEFAULT_MODEL=gpt-4o-mini
LLM_FALLBACK_MODE=graceful
LLM_FORCE_HEURISTIC=false

MCP_COMMAND=npx
MCP_ARGS=-y @futurelab-studio/latest-science-mcp@latest
MCP_SERVER_NAME=scientific-papers
MCP_SEARCH_TOOL=
MCP_TIMEOUT_SEC=30
MCP_CACHE_TTL_SEC=300

JOB_EXECUTOR_MODE=inline
WORKER_POLL_INTERVAL=3
WS_POLL_INTERVAL_SEC=1.0
